      "regex": "^/api/cameras/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/cameras/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
